{
    "info": {
        "name": "Gaming Library Tracker",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "description": "Postman requests for all REST endpoints in the Flask homework project."
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://127.0.0.1:5000"
        },
        {
            "key": "gameId",
            "value": "1"
        }
    ],
    "item": [
        {
            "name": "GET Categories",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/api/categories",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "categories"
                    ]
                }
            }
        },
        {
            "name": "GET Games",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/api/games",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "games"
                    ]
                }
            }
        },
        {
            "name": "GET Game By ID",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/api/games/{{gameId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "games",
                        "{{gameId}}"
                    ]
                }
            }
        },
        {
            "name": "POST Create Game",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"title\": \"Stardew Valley\",\n  \"platform\": \"PC\",\n  \"genre\": \"Farming Sim\",\n  \"hours_played\": 35,\n  \"rating\": 9.1,\n  \"completed\": false,\n  \"category_id\": 4\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/games",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "games"
                    ]
                }
            }
        },
        {
            "name": "PUT Replace Game",
            "request": {
                "method": "PUT",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"title\": \"Hades (Updated)\",\n  \"platform\": \"PC\",\n  \"genre\": \"Roguelike\",\n  \"hours_played\": 50,\n  \"rating\": 9.6,\n  \"completed\": true,\n  \"category_id\": 4\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/games/{{gameId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "games",
                        "{{gameId}}"
                    ]
                }
            }
        },
        {
            "name": "PATCH Update Game",
            "request": {
                "method": "PATCH",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"hours_played\": 60,\n  \"completed\": true\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/games/{{gameId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "games",
                        "{{gameId}}"
                    ]
                }
            }
        },
        {
            "name": "DELETE Game",
            "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/api/games/{{gameId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "games",
                        "{{gameId}}"
                    ]
                }
            }
        }
    ]
}